{
  "name": "quran-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "vercel-build": "tsc",
      "dev": "bun --hot src/server.ts",
    "dev:watch": "bun --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.13.0",
    "http-status": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vercel/node": "^3.0.0"
  }
}